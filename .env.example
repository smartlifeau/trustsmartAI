# Copy this file to .env for local development
# In Netlify: add each under Site Settings > Environment Variables

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# TEST keys (from Stripe Dashboard > Developers > API keys)
# Use sk_test_... for local/sandbox. Switch to sk_live_... only in prod Netlify env.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Webhook signing secret — get from Stripe CLI (local) or Dashboard (deployed)
# Local:    run `stripe listen` and copy the whsec_... it prints
# Deployed: Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
